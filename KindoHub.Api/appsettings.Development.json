{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost;Database=KindoHubDB;Trusted_Connection=True;TrustServerCertificate=True;"
  },
  "Jwt": {
    "Key": "development-secret-key-minimum-32-characters-for-hmac-sha256",
    "Issuer": "KindoHub.Api",
    "Audience": "KindoHub.Client",
    "AccessTokenMinutes": 15,
    "RefreshTokenDays": 7
  }
}
